# CI-only, NON-SECRET environment for the Blueflow integration pipeline.
# Safe to commit: contains no real credentials. Container DNS names (postgres,
# inngest) come from docker/ci/compose.blueflow.yml.

# DB host is the `postgres` compose service, not localhost
DATABASE_URL=postgres://postgres:postgres@postgres:5432/viper

BETTER_AUTH_SECRET=ci-better-auth-secret-not-for-production
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

DOMAIN_WHITELIST=example.com

# Optional VIPER integrations, unused by this test; blank keeps the app happy.
ANTHROPIC_API_KEY=
HELM_URL=
HELM_TOKEN=
NETWORK_FLOW_URL=
NETWORK_FLOW_TOKEN=
N8N_KEY=
N8N_AI_SYNC_URL=
