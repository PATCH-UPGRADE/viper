# Database URL set up to be used with Docker
DATABASE_URL=postgres://postgres:postgres@postgres:5432/viper

BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=http://localhost:3000

NEXT_PUBLIC_APP_URL=https://your-app.com

SMTP_FROM=Viper <noreply@example.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

DOMAIN_WHITELIST=example.com,example2.com

GOOGLE_OAUTH_CLIENT_ID=changeme.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

N8N_KEY=
N8N_AI_SYNC_URL=

NETWORK_FLOW_URL=
NETWORK_FLOW_TOKEN=

HELM_URL=https://helm-api.com/api/helm-get-sbom
HELM_TOKEN=

# set to minioadmin when running locally
AWS_ACCESS_KEY_ID=
AWS_REGION=us-east-1
# set to minioadmin when running locally
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Set to http://localhost:9000 to use local MinIO instead of AWS S3 (leave blank in production)
S3_ENDPOINT=

ANTHROPIC_API_KEY=

# Siemens Healthineers teamplay Fleet — outbound work orders (CDST proposals the
# user accepts). Reading /activities is configured on the Integration row; these
# three are only needed to CREATE work orders.
# The create endpoint (the integration's /activities URI is a read collection).
FLEET_WORK_ORDER_URL=
# Callback number Siemens uses for VIPER-raised orders.
FLEET_CONTACT_PHONE=
# The Fleet address record Siemens dispatches to, as JSON. Example:
# {"type":"existing","addressId":16318179,"locationName":"ADVANCED MOBILITY BY KENTUCKY","street":"611 COMMERCE CENTER DRIVE","city":"UNIVERSITY PARK","state":"IL","zip":"60484","tzCode":"","tzOffset":""}
FLEET_SITE_ADDRESS=
